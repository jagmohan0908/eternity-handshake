MCP_BEARER_TOKEN=change-me

FRAPPE_BASE_URL=https://your-frappe-site.example.com
FRAPPE_AUTHORIZATION=token api_key:api_secret
FRAPPE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36
FRAPPE_ACCEPT_LANGUAGE=en-US,en;q=0.9
FRAPPE_ORIGIN=https://your-frappe-site.example.com
FRAPPE_REFERER=https://your-frappe-site.example.com/
# Optional JSON object for Cloudflare/server-specific allow headers, for example:
# FRAPPE_EXTRA_HEADERS_JSON={"X-Server-Token":"value"}

# Optional multi-Frappe routing config. Requests choose a tenant by passing
# tenant_key, frappe_tenant, company_key, account_key, frappe_account, or domain.
# If no tenant is passed, "default" is used.
# FRAPPE_TENANTS_JSON={"default":{"base_url":"https://site-a.example.com","authorization":"token api_key:api_secret","default_template":"vobiz_ai","default_channel_account":"vobiz_main","default_language":"en"},"clinic_b":{"base_url":"https://site-b.example.com","authorization":"token api_key:api_secret","default_template":"clinic_b_template","default_channel_account":"clinic_b_channel","default_language":"en"}}
# FRAPPE_TENANTS_FILE=/etc/secrets/frappe_tenants.json

WA_DEFAULT_TEMPLATE=vobiz_dg
WA_DEFAULT_LANGUAGE=en
WA_DEFAULT_CHANNEL_ACCOUNT=Interakt SRIAAS Male
WA_TEMPLATE_VARIABLE_COUNT=1

MCP_DB_PATH=data/handshake_mcp.sqlite3
MCP_IDEMPOTENCY_TTL_SECONDS=86400
MCP_CIRCUIT_BREAKER_SECONDS=60
MCP_MAX_FRAPPE_CALLS_PER_CALL=10
MCP_MAX_WHATSAPP_SENDS_PER_CALL=1
